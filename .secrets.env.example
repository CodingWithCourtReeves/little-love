# Template for local dev secrets. Copy to `.secrets.env` (gitignored) and fill in:
#
#   cp .secrets.env.example .secrets.env
#
# scripts/dev-phones.sh auto-sources `.secrets.env` if present. Without it, the
# server runs with push disabled — exactly as before. The `.secrets.env` file is
# per-checkout (gitignored), but this template is committed, so every worktree
# and a fresh main checkout both have it on hand.
#
# APNs push (token auth). The .p8 key lives OUTSIDE the repo; we only read its
# contents here, so the secret never lands in version control.
#   1. Move the downloaded key:  mkdir -p ~/.little-love-secrets && mv ~/Downloads/AuthKey_*.p8 ~/.little-love-secrets/
#   2. Fill in the two TODOs below (the Key ID is the 10 chars in the filename).
#   The .p8 sits in $HOME, so it's shared across every worktree — set it up once.

export APNS_KEY_P8="$(cat "$HOME/.little-love-secrets/AuthKey_REPLACE_WITH_KEY_ID.p8")"
export APNS_KEY_ID="REPLACE_WITH_KEY_ID"   # the 10 chars from AuthKey_XXXXXXXXXX.p8
export APNS_TEAM_ID="9PVUX2535W"
export APNS_TOPIC="dev.littlelove.littlelove"
export APNS_ENV="sandbox"

# Cloudflare TURN (voice calling). A "TURN key" is a long-lived server-side
# secret the API server uses to mint short-lived ICE credentials per call. It is
# NOT Terraform-managed (the pinned cloudflare provider has no TURN resource) —
# create it once in the dashboard (Realtime → TURN → Create) or via the API, the
# same out-of-band pattern as the R2 S3 keys. See infra/cloudflare/turn.tf.
#   TURN_KEY_ID    = the `uid`  returned when the key is created
#   TURN_API_TOKEN = the `key`  returned when the key is created (keep server-side)
# Use a DEDICATED dev key (e.g. "littlelove-dev") so dev traffic never touches
# prod metering. Leave unset to run with calls degraded to direct/STUN only.
export TURN_KEY_ID="REPLACE_WITH_DEV_TURN_KEY_UID"
export TURN_API_TOKEN="REPLACE_WITH_DEV_TURN_KEY_SECRET"
